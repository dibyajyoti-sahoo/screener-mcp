# Screener.in credentials.
#
# stdio transport: these env vars are read at startup.
# SSE transport:   credentials are supplied per-connection by each client when
#                  it opens /sse (request headers or query params), so these are
#                  optional / for local testing only.
#SCREENER_USERNAME=applicationmaintainer@gmail.com
#SCREENER_PASSWORD=Dibya@123

# Transport + SSE binding (all optional; CLI flags override these).
# MCP_TRANSPORT=stdio   # or: sse
MCP_TRANSPORT=sse
HOST=0.0.0.0
PORT=11345
LOG_LEVEL=INFO

# Landing-page (/) hero image. Absolute path or path relative to where you run
# the server. If unset, a bundled src/screener_mcp/static/banner.* is used.
#INDEX_IMAGE=/Users/dibyajyotisahoo/Download/Gemini_Generated_Image_uxu5lduxu5lduxu5.png

# Auth gate. When AUTH_SERVER_URL is set, every /sse connection must sign in
# (HTTP Basic, validated via {AUTH_SERVER_URL}/auth/signin) or it is rejected
# with 401. Screener data is then fetched using the SCREENER_* account above,
# so uncomment SCREENER_USERNAME / SCREENER_PASSWORD for full (non-public) data.
# Clients send SSO_USERNAME / SSO_PASSWORD on each /sse connection; the server
# validates via /auth/signin and caches the result (hashed) to avoid re-calling
# the auth server on every reconnect. On cache miss/expiry it auto signs in again.
AUTH_SERVER_URL=https://secure.dibyajyoti.dpdns.org
# AUTH_ENABLED=true       # force on/off; defaults to on whenever AUTH_SERVER_URL is set
# AUTH_TIMEOUT=10         # seconds — auth server request timeout
# AUTH_CACHE_TTL=300      # seconds a successful sign-in stays cached
